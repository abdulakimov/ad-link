# ---- core ----
# docker-compose maps postgres‚Üí5435 and redis‚Üí6380 to avoid clashing with local services
DATABASE_URL=postgresql://adlink:adlink@localhost:5435/adlink?schema=public
REDIS_URL=redis://localhost:6380
APP_SECRET=change-me-32-chars-minimum-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
WEB_ORIGIN=http://localhost:3000
API_PORT=4000

# ---- web ----
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- google oauth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ---- telegram login ----
# bot token from @BotFather (API only ‚Äî never exposed to the browser)
TELEGRAM_BOT_TOKEN=
# bot username + numeric id (public) ‚Äî used by the web login button.
# set both in apps/web/.env.local (Next reads env from the app dir, not the repo root).
NEXT_PUBLIC_TELEGRAM_BOT=
NEXT_PUBLIC_TELEGRAM_BOT_ID=

# ---- meta (verify latest API version at build time) ----
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:4000/integrations/meta/oauth/callback

# ---- fx (dated rates) ----
FX_PROVIDER_API_KEY=

# ---- observability (optional in dev) ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
