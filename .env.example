# ---- core ----
# docker-compose maps postgresâ†’5435 and redisâ†’6380 to avoid clashing with local services
DATABASE_URL=postgresql://adlink:adlink@localhost:5435/adlink?schema=public
REDIS_URL=redis://localhost:6380
APP_SECRET=change-me-32-chars-minimum-secret
