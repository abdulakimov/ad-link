{
  "name": "@adlink/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/main.js",
    "start:dev": "concurrently -k -n tsc,node \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --watch --enable-source-maps dist/main.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(api) eslint added in Phase 1\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@adlink/core": "workspace:*",
    "@adlink/db": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/node": "^8.47.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.2.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
